<% layout("layouts/boilerplate.ejs") %>
  <div class="row show card mt-3">
    <div class="col-8 p-0">
      <img src="<%= listing.image %>" class="show card-img" alt="...">
    </div>
    <div class="show col-4 card-body">
      <h3 class="card-title">

        <%= listing.title %>
      </h3>
      <p class="show card-text">
        <%= listing.description %>
      </p>
      <p class="show card-text">&#8377; <%= listing.price.toLocaleString("en-IN") %>
      </p>
      <p class="show card-text"><small class="text-body-secondary">
          <%= listing.location %>,<%= listing.country %>
        </small></p>
      <%if(crrUser && crrUser._id.equals(listing.owner._id)){%>
        <div class="buttons">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-secondary">Edit</a>

          <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" style="display: inline-block;">
            <button class="btn btn-secondary">Delete this listing</button>
          </form>
        </div>
        <%}%>
          <p class="show card-text"><small class="text-body-secondary">
              Created by: <%= listing.owner.username %>
            </small></p>
    </div>
  </div>

  <hr class="review-breaker">
  <%if(crrUser){%>
    <h3 id="head">Add Reviews</h3>
    <form method="POST" action="/listings/<%=listing._id%>/review" class="needs-validation mb-3" novalidate>
      <div class="review-rating mb-3">
        <label for="rating" class="form-label">Rating:&nbsp;&nbsp;</label>
        <fieldset class="starability-basic">
  <!-- <legend>First rating:</legend> -->
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
      </div>
      <div class="mb-3">
        <label for="comment" class="form-label">Comment</label>
        <textarea name="review[comment]" placeholder="Enter Comment" class="form-control" id="comment"
          required></textarea>
        <div class="invalid-feedback">
          Please provide a valid Comment.
        </div>

      </div>
      <button class="btn btn-dark">Add Review</button>
    </form>
    <hr class="review-breaker">
    <%}%>

      <h3 id="head">All Reviews</h3>
      <div class="review-container">

        <% let otherReviews=[];
        for (let review of listing.reviews) { 
          if (crrUser && review.author._id.equals(crrUser._id)) { %>
          <div class="my review-card card col-5">
            <div class="review-card-body card-body">
              <h5 class="card-title ">@<%= review.author.username %>
              </h5>
              <h6 class="review-rating review-card-subtitle card-subtitle mb-2 text-body-secondary">Rating:&nbsp;&nbsp;<p class="review-rating starability-result" data-rating="<%= review.rating %> ">  </p>
              </h6>
              <p class="review-card-text card-text">
                <%= review.comment %>
              </p>
              <p class="review-card-textcard-text"><small class="text-body-secondary">
                  <%= new Date(review.created).toLocaleString('en-US', { weekday: 'short' , month: 'short' ,
                    day: 'numeric' , hour: '2-digit' , minute: '2-digit' , hour12: true }) %>
                </small>
              </p>
              <div class="buttons">
                  <a href="/listings/<%= listing._id %>/review/<%= review._id %>/edit"
                    class="btn btn-secondary">Edit</a>

                  <form method="POST" action="/listings/<%= listing._id %>/review/<%= review._id %>?_method=DELETE"
                    style="display: inline-block;">
                    <button class="btn btn-secondary">Delete this Review</button>

                  </form>
                </div>
            </div>
          </div>
          <%} else { 
            otherReviews.push(review); 
          } 
        } 
        %>
        <hr class="review-breaker">
        <%
        for (review of otherReviews) { %>
              <div class="review-card card col-5">
                <div class="review-card-body card-body">
                  <h5 class="card-title ">@<%= review.author.username %>
                  </h5>
                  <h6 class="review-rating review-card-subtitle card-subtitle mb-2 text-body-secondary">Rating:&nbsp;&nbsp;<p class="review-rating starability-result" data-rating="<%= review.rating %>">  </p>
                  </h6>
  
                  <p class="review-card-text card-text">
                    <%= review.comment %>
                  </p>
                  <p class="review-card-textcard-text"><small class="text-body-secondary">
                      <%= new Date(review.created).toLocaleString('en-US', { weekday: 'short' , month: 'short' ,
                        day: 'numeric' , hour: '2-digit' , minute: '2-digit' , hour12: true }) %>
                    </small>
                  </p>
                      </form>
                </div>
              </div>

              <% } %>
      </div>
<% layout("layouts/boilerplate.ejs") %>

    <div class="row mt-3">
        <h3 class="col-6 offset-3">Log In</h3>
        <div class="col-6 offset-3">
            <form method="POST" action="/logIn" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="title" class="form-label">Enter Username</label>
                    <input name="username" placeholder="Username" type="text" class="form-control" id="title"
                        required />
                    <div class="invalid-feedback">
                        Please enter a User Name.
                    </div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Enter Password</label>
                    <input name="password" placeholder="Password" type="password" class="form-control" id="title"
                        required />
                    <div class="invalid-feedback">
                        Please enter a Password.
                    </div>
                </div>

                <button class="btn btn-dark">logIn</button>
            </form>
        </div>

    </div>